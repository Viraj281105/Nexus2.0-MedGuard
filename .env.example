# =============================================================================
# MedGuard AI + AdvocAI — Environment Variables Template
# =============================================================================
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env and fill in your actual values
# 3. DO NOT commit .env file to version control
# 4. Add .env to .gitignore if not already there
# =============================================================================

# --- LLM Backend Configuration ---
LLM_BACKEND=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Ollama (optional — for local development only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Database Configuration (PostgreSQL) ---
# IMPORTANT: These values MUST match docker-compose.yml
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=advocai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=advocai123
PERSISTENCE_BACKEND=postgres
DB_ENABLE_POOL=true

# --- Authentication Configuration ---
# DEMO_MODE: Disables JWT authentication (development only!)
DEMO_MODE=false

# JWT_SECRET: Used to sign JWT tokens
# IMPORTANT: Generate a strong random value for production
# Command: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_64_char_string

# Token expiration time (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Third-party Services (Optional) ---
PUBMED_API_KEY=

# =============================================================================
# IMPORTANT NOTES:
# =============================================================================
# 1. Get GROQ_API_KEY from: https://console.groq.com/keys
# 2. Generate JWT_SECRET with Python (see command above)
# 3. For local development:
#    - Keep POSTGRES_* matching docker-compose.yml
#    - Keep PERSISTENCE_BACKEND=postgres
#    - DEMO_MODE can be true/false (false for testing auth)
# 4. For production deployment:
#    - Use strong database password (not advocai123)
#    - Generate and store JWT_SECRET securely
#    - Set DEMO_MODE=false
#    - Use environment-specific configuration
# 5. Frontend configuration:
#    - Create frontend/.env.local with NEXT_PUBLIC_API_URL
#    - Example: NEXT_PUBLIC_API_URL=http://localhost:8000
# =============================================================================

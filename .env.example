# =============================================================================
# MedGuard AI + AdvocAI — Environment Variables Template
# =============================================================================
# Copy this file to backend/.env and fill in your values:
#   cp .env.example backend/.env
# =============================================================================

# --- LLM Backend ---
LLM_BACKEND=groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Ollama (optional — for local development only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=advocai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=advocai123
PERSISTENCE_BACKEND=json

# --- Authentication ---
JWT_SECRET=change_this_to_a_random_64_char_string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- PubMed API (optional) ---
PUBMED_API_KEY=

# ========================================================
# AdvocAI Backend Configuration (.env)
# ========================================================
# Copy this file to .env and fill in your values

# ========================================================
# Demo Mode - Disable Authentication for Testing
# ========================================================
# Set to "true" to bypass JWT authentication
# WARNING: Only use for demos and testing, never in production!
DEMO_MODE=false

# ========================================================
# LLM Configuration
# ========================================================
# Primary LLM backend (groq or ollama)
LLM_BACKEND=groq

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# Ollama Configuration (if using local Ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ========================================================
# Database Configuration
# ========================================================
# PostgreSQL connection details
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=advocai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=advocai123

# Persistence backend (postgres or json)
PERSISTENCE_BACKEND=postgres

# ========================================================
# Authentication
# ========================================================
# JWT Secret Key - Change this in production!
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Token expiry in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========================================================
# Optional APIs
# ========================================================
# PubMed API Key for clinical evidence search
PUBMED_API_KEY=your_pubmed_key_here

# Hugging Face API Token (for model downloads)
HF_TOKEN=your_huggingface_token_here
